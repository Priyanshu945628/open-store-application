# Open Store — Environment Variables
# Copy all values to your hosting platform's env vars.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-string

# ── Frontend CORS ─────────────────────────────────────────────────────────────
CORS_ORIGIN=https://your-frontend.vercel.app

# ── Admin Access ──────────────────────────────────────────────────────────────
# Only this handle can access #/admin. Leave empty to disable.
OWNER_HANDLE=yourhandle

# ── Supabase (persistent DB + small files < 5MB) ─────────────────────────────
# Free tier: 500MB, no credit card.
# 1. Sign up at https://supabase.com → New Project → SQL Editor → run table SQL.
# 2. Settings → API → copy Project URL and Service Role Key (NOT anon key).
SUPABASE_URL=
SUPABASE_KEY=

# ── Telegram (large files ≥ 5MB: videos, shorts) ─────────────────────────────
# Videos/shorts always go to Telegram. Leave blank to skip.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DB_CHAT=
TELEGRAM_MEDIA_CHAT=
