# Open Store — Environment Variables
# Copy all values to your hosting platform's env vars.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-string

# ── Frontend CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all.
CORS_ORIGIN=https://your-frontend.vercel.app

# ── Admin Access ──────────────────────────────────────────────────────────────
# Only the user with this handle can access the admin panel (#/admin).
# Leave empty to disable admin entirely.
OWNER_HANDLE=yourhandle

# ── Supabase (persistent DB — recommended for Vercel) ────────────────────────
# Survives cold starts. Free tier: 500MB, no credit card.
# 1. Sign up at https://supabase.com → New Project → SQL Editor → run the table creation SQL.
# 2. Settings → API → copy Project URL and Service Role Key.
SUPABASE_URL=
SUPABASE_KEY=

# ── Telegram Storage (optional, backup) ──────────────────────────────────────
# Adds Telegram as a write-through backup on top of Supabase.
# Leave blank to skip Telegram backup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DB_CHAT=
TELEGRAM_MEDIA_CHAT=

# ── Local Bot API Server (optional, for 2GB uploads) ─────────────────────────
# Uncomment and set to your local server URL after setup.
# TELEGRAM_API_URL=http://127.0.0.1:8081
