# Open Store — Environment Variables
# Copy this file to server/.env and fill in the values.
# The server reads these at startup; restart after changes.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# ── Telegram Storage (optional) ───────────────────────────────────────────────
# Leave these blank (or unset) to run in memory-only mode (good for development).
# Fill them in to enable Telegram as the durable store (production-ready).
#
# How to set up:
#   1. Open Telegram → message @BotFather → /newbot → follow prompts → copy token.
#   2. Create a new PRIVATE channel: "Open Store DB" (for structured records).
#   3. Create a second PRIVATE channel: "Open Store Media" (for uploaded files).
#      (You can use the same channel for both — just set both vars to the same ID.)
#   4. In each channel: Settings → Administrators → Add Administrator → select your bot
#      → enable "Post Messages" → Save.
#   5. Get the channel ID: forward any message from the channel to @userinfobot,
#      or send a message and call https://api.telegram.org/bot<TOKEN>/getUpdates.
#      The ID looks like -1001234567890 (negative, starts with -100 for channels).

TELEGRAM_BOT_TOKEN=
TELEGRAM_DB_CHAT=
TELEGRAM_MEDIA_CHAT=

# ── Local Bot API Server (optional, for 2GB uploads) ──────────────────────────
# Uncomment and set to your local server URL after setup.
# See: https://github.com/tdlib/telegram-bot-api
# TELEGRAM_API_URL=http://127.0.0.1:8081
